# Normalize line endings (satır sonlarını normalize et)
* text=auto

# Source files (kaynak kodlar) = LF
*.ts  text eol=lf
*.tsx text eol=lf
*.js  text eol=lf
*.jsx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.json text eol=lf
*.md  text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Windows scripts (Windows scriptleri)
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf
